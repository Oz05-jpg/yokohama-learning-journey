@model List<YokohamaEF.Models.Project>

<div class="container mt-4">
    <h1>Projects</h1>
    <a href="/Project/Create" class="btn btn-primary mb-3">+ เพิ่ม Project</a>

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>ชื่อ Project</th>
                <th>คำอธิบาย</th>
                <th>สมาชิก</th>
                <th>จัดการ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var project in Model)
            {
                <tr>
                    <td>@project.Name</td>
                    <td>@project.Description</td>
                    <td>
                        @string.Join(", ", project.Employees.Select(e => e.Name))
                    </td>
                    <td>
                        <a href="/Project/Assign/@project.Id" class="btn btn-warning btn-sm">Assign</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
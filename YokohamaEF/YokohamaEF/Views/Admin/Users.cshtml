@model List<Microsoft.AspNetCore.Identity.IdentityUser>

<h2>Manage Users</h2>

<table border="1" cellpadding="8">
    <thead>
        <tr>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Email</td>
                <td>
                    <a asp-action="AssignRole" asp-route-userId="@user.Id">Assign Role</a> |
                    <a asp-action="DeleteUser" asp-route-userId="@user.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
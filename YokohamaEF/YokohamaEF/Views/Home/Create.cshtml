@model YokohamaEF.Models.Employee

<div class="container mt-4">
    <h1>เพิ่มพนักงาน</h1>

    <form method="post" action="/Home/Create" class="mt-3" style="max-width: 400px;">
        <div class="mb-3">
            <label class="form-label">ชื่อ</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">แผนก</label>
            <select asp-for="DepartmentId" asp-items="ViewBag.Departments" class="form-control">
                <option value="">-- เลือกแผนก --</option>
            </select>
            <span asp-validation-for="DepartmentId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">ค่าแรงต่อชั่วโมง</label>
            <input asp-for="HourlyRate" class="form-control" />
            <span asp-validation-for="HourlyRate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">ชั่วโมงที่ทำงาน</label>
            <input asp-for="HoursWorked" class="form-control" />
            <span asp-validation-for="HoursWorked" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">เงินเดือน</label>
            <input asp-for="Salary" class="form-control" />
            <span asp-validation-for="Salary" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">บันทึก</button>
        <a href="/Home/Employees" class="btn btn-secondary ms-2">ยกเลิก</a>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

@model List<YokohamaMVC.Models.Employee>

<div class="container mt-4">
    <h1>รายชื่อพนักงาน</h1>
    <a href="/Home/Create" class="btn btn-primary mb-3">+ เพิ่มพนักงาน</a>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>ชื่อ</th>
                <th>แผนก</th>
                <th>เงินเดือน</th>
                <th>ค่าแรง/ชม.</th>
                <th>ชม.ทำงาน</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.Id</td>
                    <td>@emp.Name</td>
                    <td>@emp.Department</td>
                    <td>@emp.Salary.ToString("N0")</td>
                    <td>@emp.HourlyRate</td>
                    <td>@emp.HoursWorked</td>
                    
                    <!--แก้ไข ลบ -->
                    <td>
                        <a href="/Home/Edit/@emp.Id" class="btn btn-sm btn-warning">แก้ไข</a>
                        <a href="/Home/Delete/@emp.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('ลบ @emp.Name ใช่ไหม?')">ลบ</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>